{
  "manifest_version": 3,
  "name": "RaceMann Manager Sync",
  "version": "1.0.0",
  "description": "Синхронизация данных менеджеров гонок в RaceMann",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://v-karting-sev.racemann.com/*",
    "ws://localhost:8765/*",
    "http://localhost:8765/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://v-karting-sev.racemann.com/Race/*",
        "https://v-karting-sev.racemann.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RaceMann Sync"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://v-karting-sev.racemann.com/*"]
    }
  ]
}